# Google Calendar ID to sync lunch menus to
# Default: "primary" (your main Google Calendar)
# To use a specific calendar, get the Calendar ID from Google Calendar settings
LUNCH_GCAL_ID=primary

# Run the sync immediately when container starts
# Useful for testing or initial setup
# Values: true or false
RUN_ON_STARTUP=false

# SchoolCafe school/district identifiers
# School UUID from SchoolCafe (shown in API requests for your school)
SCHOOLCAFE_SCHOOL_ID=10de21a6-64e7-4bd0-9d8c-8a17d2cfe022
# Numeric district ID
SCHOOLCAFE_DISTRICT_ID=400
# Grade level to fetch menus for (zero-padded, e.g. "08" for 8th grade)
SCHOOLCAFE_GRADE=08
# Serving line name (must match what SchoolCafe returns for your school)
SCHOOLCAFE_SERVING_LINE=Lunch
# Meal type filter
SCHOOLCAFE_MEAL_TYPE=Lunch
